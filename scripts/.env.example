# Actuary Sleuth 环境变量配置模板
# 复制为 .env 并根据实际环境修改路径（支持绝对路径）

# ===== 数据路径 =====
# SQLite 数据库路径（相对于 scripts/ 或绝对路径）
# SQLITE_DB=data/actuary.db

# LanceDB 向量数据库路径（相对于 scripts/ 或绝对路径）
# LANCEDB_URI=data/lancedb

# 法规文件目录（相对于 scripts/ 或绝对路径）
# REGULATIONS_DIR=references

# 知识库版本目录（相对于 scripts/ 或绝对路径）
# KB_VERSION_DIR=lib/rag_engine/data/kb

# ===== LLM 配置 =====
# ZHIPU_API_KEY=your_api_key_here
