# Actuary Sleuth 环境变量配置模板
# 复制为 .env 并填入实际值

# ===== API 密钥 =====
# ZHIPU_API_KEY=your_api_key_here
# MinMax_API_KEY=your_api_key_here
# FEISHU_APP_ID=your_app_id_here
# FEISHU_APP_SECRET=your_app_secret_here
# FEISHU_TARGET_GROUP_ID=your_group_id_here

# ===== 数据路径 =====
# DATA_PATHS_SQLITE_DB=/path/to/actuary.db
# DATA_PATHS_REGULATIONS_DIR=/path/to/references
# DATA_PATHS_KB_VERSION_DIR=/path/to/kb
# DATA_PATHS_EVAL_SNAPSHOTS_DIR=/path/to/eval/snapshots
# DATA_PATHS_MODELS_DIR=/path/to/models/reranker
# DATA_PATHS_TOOLS_DIR=/path/to/tools/hanxiao-llama.cpp

# ===== Ollama =====
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_TIMEOUT=120

# ===== Zhipu =====
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# ZHIPU_TIMEOUT=60
# ZHIPU_TEMPERATURE=0.1
# ZHIPU_MAX_TOKENS=16384

# ===== MiniMax =====
# MINMAX_BASE_URL=https://api.minimaxi.com/v1
# MINMAX_TIMEOUT=60
# MINMAX_TEMPERATURE=0.1
# MINMAX_MAX_TOKENS=16384

# ===== LLM 提供者配置 =====
# LLM_EMBED_PROVIDER=ollama
# LLM_EMBED_MODEL=qllama/bge-m3:q4_k_m
# LLM_EVAL_PROVIDER=zhipu
# LLM_EVAL_MODEL=glm-4-flash
# LLM_EVAL_TIMEOUT=180
# LLM_AUDIT_PROVIDER=zhipu
# LLM_AUDIT_MODEL=glm-4-flash
# LLM_AUDIT_TIMEOUT=120
# LLM_QA_PROVIDER=zhipu
# LLM_QA_MODEL=glm-4-flash
# LLM_NAME_PARSER_PROVIDER=zhipu
# LLM_NAME_PARSER_MODEL=glm-4-flash
# LLM_NAME_PARSER_TIMEOUT=120
# LLM_OCR_PROVIDER=zhipu
# LLM_OCR_MODEL=glm-4-flash
# LLM_OCR_TIMEOUT=120

# ===== Debug =====
# DEBUG=false
