graph TB
    subgraph UserLayer["用户交互层"]
        User["用户/审核员"]
        CLI["命令行工具 audit.py"]
    end

    subgraph FeishuLayer["飞书集成层"]
        FeishuAPI["飞书文档 API"]
        FeishuPush["飞书消息推送"]
    end

    subgraph AppLayer["应用层 - 流程编排"]
        Orchestrator["审核流程编排器"]

        subgraph PreprocessPipe["预处理管道"]
            Fetcher["文档获取器"]
            Normalizer["文档规范化"]
            Classifier["产品分类器"]
            Extractor["信息提取器"]
            Validator["质量验证器"]
        end

        subgraph AuditPipe["审核管道"]
            CheckModule["负面清单检查"]
            ScoreModule["定价分析"]
            Auditor["合规审核器"]
        end

        subgraph ReportGen["报告生成"]
            Reporter["报告生成器"]
            DocxExporter["Word导出器"]
        end
    end

    subgraph ServiceLayer["核心服务层"]
        subgraph RAGEngineLayer["RAG引擎"]
            RAGEngine["RAG查询引擎"]
            IndexMgr["向量索引管理器"]
            DocParser["法规文档解析器"]
            DataImporter["法规数据导入器"]
        end

        subgraph RetrievalLayer["混合检索系统"]
            VectorRetriever["向量检索器"]
            KeywordRetriever["关键词检索器"]
            Fusion["结果融合器"]
            Tokenizer["中文分词器"]
        end

        subgraph LLMLayer["LLM抽象层"]
            LLMFactory["LLM客户端工厂"]
            ZhipuClient["智谱AI客户端"]
            OllamaClient["Ollama客户端"]
            Cache["LLM响应缓存"]
            Metrics["性能监控"]
        end
    end

    subgraph DataLayer["数据存储层"]
        subgraph VectorDBLayer["向量数据库"]
            LanceDB["LanceDB"]
            VectorTable["向量表"]
        end

        subgraph RelDBLayer["关系数据库"]
            SQLite["SQLite"]
            ConnPool["连接池"]
            RegTable["法规表"]
            AuditTable["审核历史"]
            NegativeTable["负面清单"]
        end

        subgraph FileStorage["文件存储"]
            Markdown["法规文档"]
            Reports["审核报告"]
        end
    end

    subgraph ExternalLayer["外部服务"]
        ZhipuAPI["智谱AI API"]
        OllamaSVC["Ollama服务"]
    end

    User --> CLI
    CLI --> Orchestrator
    FeishuAPI --> Fetcher
    DocxExporter --> FeishuPush

    Orchestrator --> Fetcher
    Fetcher --> Normalizer
    Normalizer --> Classifier
    Classifier --> Extractor
    Extractor --> Validator
    Validator --> CheckModule

    CheckModule --> ScoreModule
    ScoreModule --> Auditor
    Auditor --> Reporter
    Reporter --> DocxExporter

    Auditor --> RAGEngine
    RAGEngine --> VectorRetriever
    RAGEngine --> KeywordRetriever
    VectorRetriever --> Fusion
    KeywordRetriever --> Fusion

    DataImporter --> DocParser
    DocParser --> IndexMgr
    IndexMgr --> LanceDB
    DataImporter --> SQLite

    RAGEngine --> LLMFactory
    Auditor --> LLMFactory
    Extractor --> LLMFactory
    LLMFactory --> ZhipuClient
    LLMFactory --> OllamaClient

    ZhipuClient --> Cache
    ZhipuClient --> Metrics
    ZhipuClient --> ZhipuAPI
    OllamaClient --> OllamaSVC

    VectorRetriever --> LanceDB
    IndexMgr --> LanceDB
    LanceDB --> VectorTable

    Auditor --> SQLite
    CheckModule --> SQLite
    SQLite --> ConnPool
    ConnPool --> RegTable
    ConnPool --> AuditTable
    ConnPool --> NegativeTable
